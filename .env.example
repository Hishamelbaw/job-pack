# Which LLM backend to use: hosted_ollama | claude_api | local_ollama
LLM_BACKEND=hosted_ollama

# hosted_ollama backend (CLASS_OLLAMA_BASE_URL and CLASS_OLLAMA_MODEL are
# optional — shown here at their defaults; only CLASS_OLLAMA_API_KEY is required)
CLASS_OLLAMA_BASE_URL=https://ollama.com
CLASS_OLLAMA_API_KEY=
CLASS_OLLAMA_MODEL=gpt-oss:120b

# claude_api backend
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# local_ollama backend
LOCAL_OLLAMA_BASE_URL=http://localhost:11434
LOCAL_OLLAMA_MODEL=

# Persistence
DATABASE_URL=sqlite:///./job_pack.db

# Comma-separated list of origins allowed to call this API (the deployed
# Netlify frontend URL, plus any local static-server origin used for dev).
# e.g. https://job-pack.netlify.app,http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=
